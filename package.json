{
  "name": "markdown-to-html-preview",
  "version": "1.0.0",
  "description": "Convert Markdown to HTML from the CLI and preview it in the browser.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "node --watch --loader ts-node/esm src/index.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "markdown",
    "html",
    "preview",
    "nodejs"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "marked": "^15.0.12"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
