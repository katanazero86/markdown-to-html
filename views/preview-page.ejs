<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= seo.title %></title>
    <meta name="description" content="<%= seo.metaDescription %>">
    <meta name="robots" content="<%= seo.robotsContent %>">
    <meta name="author" content="katanazero86">
    <meta name="application-name" content="Markdown to HTML Preview">
    <meta name="theme-color" content="#b3541e">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Markdown to HTML Preview">
    <meta property="og:title" content="<%= seo.title %>">
    <meta property="og:description" content="<%= seo.metaDescription %>">
    <meta property="og:url" content="<%= seo.canonicalUrl %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= seo.title %>">
    <meta name="twitter:description" content="<%= seo.metaDescription %>">
    <% if (seo.canonicalUrl) { %>
    <link rel="canonical" href="<%= seo.canonicalUrl %>">
    <% } %>
    <link rel="stylesheet" href="/styles/preview-page.css">
    <script type="application/ld+json"><%- seo.jsonLd %></script>
    <script>
      window.previewPageConfig = {
        documentEndpoint: '/document',
        renderEndpoint: '/render'
      };
    </script>
    <script type="module" src="/scripts/preview-page.js" defer></script>
  </head>
  <body>
    <main class="page-shell">
      <section class="hero">
        <span class="eyebrow">Interactive Preview</span>
        <h1><%= seo.title %></h1>
        <p>Seeded from <%= sourceName %>. Edit Markdown on the left and download either side whenever needed.</p>
      </section>
      <section class="workspace">
        <section class="panel">
          <header class="panel-header">
            <div class="panel-heading">
              <strong>Markdown Input</strong>
              <span>Editable source</span>
            </div>
            <button id="download-markdown" class="download-button" type="button">Download .md</button>
          </header>
          <div class="editor-shell">
            <pre id="line-gutter" class="line-gutter" aria-hidden="true"></pre>
            <textarea id="markdown-editor" class="editor" spellcheck="false" wrap="off"><%= markdownText %></textarea>
          </div>
        </section>
        <section class="panel">
          <header class="panel-header">
            <div class="panel-heading">
              <strong>HTML Preview</strong>
              <span>Rendered document</span>
            </div>
            <button id="download-html" class="download-button" type="button">Download .html</button>
          </header>
          <article id="preview-body" class="preview-body"><%- bodyContent %></article>
        </section>
      </section>
      <footer class="page-footer">
        <span>Project Repository</span>
        <a href="https://github.com/katanazero86/markdown-to-html" target="_blank" rel="noreferrer">https://github.com/katanazero86/markdown-to-html</a>
      </footer>
    </main>
  </body>
</html>
